[Unit]
Description=Control Portal — fleet ops dashboard
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/control
ExecStart=/usr/bin/python3 /home/ubuntu/control/app.py
Restart=on-failure
RestartSec=5
Environment="PYTHONUNBUFFERED=1"
EnvironmentFile=-/home/ubuntu/.openclaw/.env
EnvironmentFile=-/home/ubuntu/control/.flask-secret-env

[Install]
WantedBy=default.target
